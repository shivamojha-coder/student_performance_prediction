# Copy this file to .env and fill values.
# Gmail SMTP setup:
# 1) Enable 2-Step Verification on your Google account.
# 2) Generate App Password from https://myaccount.google.com/apppasswords
# 3) Paste 16-char app password below.

SECRET_KEY=dev-secret-key-change-in-production

SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Google OAuth (required for Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Optional: set if callback host is different from request host
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
# OAUTH_REDIRECT_BASE_URL=http://localhost:5000
